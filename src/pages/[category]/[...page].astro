---
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import keywordsData from '../../../keywords.json';

export function getStaticPaths() {
  const cats = [
    { name: 'Aparate Aer Conditionat', slug: 'aparate-aer-conditionat', desc: 'Modele Beko cu specificatii, preturi si pareri reale din piata Romania.' },
    { name: 'Instalare si Montaj', slug: 'instalare-montaj', desc: 'Costuri de montaj, pasi de instalare si ce trebuie sa stii inainte.' },
    { name: 'Intretinere si Curatare', slug: 'intretinere-curatare', desc: 'Curatare filtre, mentenanta periodica si rezolvarea problemelor frecvente.' },
    { name: 'Eficienta Energetica', slug: 'eficienta-energetica', desc: 'Consum real pe ora, diferente intre clase energetice si costuri lunare.' },
    { name: 'Sfaturi Practice', slug: 'ghiduri-sfaturi', desc: 'Dimensionare BTU, comparatii intre modele si sfaturi de achizitie.' },
  ];

  function slugify(text: string) {
    return text.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
  }

  const done = (keywordsData.completed || []).map((item: any) => ({
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: slugify(item.keyword),
    excerpt: item.excerpt || '',
    image: `/images/articles/${slugify(item.keyword)}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date || new Date().toISOString(),
  }));

  const PER = 12;
  const paths: any[] = [];

  for (const cat of cats) {
    const list = done.filter((a: any) => a.categorySlug === cat.slug)
      .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
    const pages = Math.max(1, Math.ceil(list.length / PER));

    for (let p = 1; p <= pages; p++) {
      paths.push({
        params: { category: cat.slug, page: p === 1 ? undefined : String(p) },
        props: { catName: cat.name, catSlug: cat.slug, catDesc: cat.desc, articles: list.slice((p - 1) * PER, p * PER), cur: p, total: pages },
      });
    }
  }
  return paths;
}

const { catName, catSlug, catDesc, articles, cur, total } = Astro.props;
---

<Layout title={`${catName} | AerConditionatBeko.ro`} description={catDesc}>
  <div data-entry-head>
    <div class="shell">
      <nav data-crumbs>
        <a href="/">Acasa</a>
        <span>/</span>
        <span style="color: var(--color-n-300)">{catName}</span>
      </nav>
      <h1 data-entry-title>{catName}</h1>
      <p style="color: var(--color-n-500); max-width: 560px; margin-bottom: 0">{catDesc}</p>
    </div>
  </div>

  <section data-block>
    <div class="shell">
      {articles.length > 0 ? (
        <h2 class="sr-only">Articole {catName}</h2>
        <div data-posts>
          {articles.map((a: any) => (
            <ArticleCard title={a.title} slug={a.slug} excerpt={a.excerpt} image={a.image} category={a.category} categorySlug={a.categorySlug} date={a.date} />
          ))}
        </div>
      ) : (
        <p style="text-align:center; color: var(--color-n-400); padding: 40px 0">Lucram la articole. Revino curand!</p>
      )}

      {total > 1 && (
        <nav data-pages>
          {cur > 1 && <a href={cur === 2 ? `/${catSlug}/` : `/${catSlug}/${cur - 1}/`} data-page>&larr;</a>}
          {Array.from({ length: total }, (_, i) => i + 1).map(p => (
            <a href={p === 1 ? `/${catSlug}/` : `/${catSlug}/${p}/`} data-page={p === cur ? 'current' : undefined}>{p}</a>
          ))}
          {cur < total && <a href={`/${catSlug}/${cur + 1}/`} data-page>&rarr;</a>}
        </nav>
      )}
    </div>
  </section>
</Layout>
