---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Pagina nu a fost gasita | AerConditionatBeko.ro"
  description="Pagina cautata nu exista sau a fost mutata."
>
  <div class="shell" style="padding: 80px 1.25rem; text-align: center; min-height: 50vh; display: flex; flex-direction: column; align-items: center; justify-content: center;">
    <h1 style="font-size: clamp(2rem, 5vw, 3.5rem); color: var(--color-n-800); margin-bottom: 12px;">404</h1>
    <p style="font-size: 1.1rem; color: var(--color-n-500); margin-bottom: 28px;">Pagina cautata nu exista sau a fost mutata.</p>
    <a href="/" data-btn="fill">Inapoi la pagina principala</a>
  </div>
</Layout>
