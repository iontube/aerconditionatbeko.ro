---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact | AerConditionatBeko.ro" description="Contacteaza echipa AerConditionatBeko.ro pentru intrebari, sugestii sau colaborari.">
  <div data-contact-wrap>
    <h1>Contact</h1>
    <div data-contact-box>
      <div data-contact-icon><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 4L12 13 2 4"/></svg></div>
      <p>Pentru intrebari, sugestii sau colaborari:</p>
      <a href="mailto:contact@aerconditionatbeko.ro" data-contact-email>contact@aerconditionatbeko.ro</a>
      <p style="color: var(--color-n-400); margin-top: 10px; margin-bottom: 0; font-size: .88rem">Raspundem in 24-48 de ore.</p>
    </div>
  </div>
</Layout>
